SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SCOPES=read_products,write_products
APP_NAME=PixelMint Studio
# Coolify Postgres example:
# DATABASE_URL=postgresql://postgres:password@your-coolify-db-host:5432/postgres?schema=public
# If your Coolify database requires SSL, append: &sslmode=require
DATABASE_URL=postgresql://postgres:password@db-host:5432/postgres?schema=public
APP_PORT=3005
