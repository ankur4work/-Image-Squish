{% assign badge = block.settings.badge | strip %}
{% assign heading = block.settings.heading | strip %}
{% assign body = block.settings.body | strip %}

<div
  class="imagesquish-product-media-note"
  {{ block.shopify_attributes }}
  style="
    border: 1px solid {{ block.settings.border_color }};
    border-radius: 12px;
    padding: 16px;
    background: {{ block.settings.background_color }};
    color: #1E293B;
  "
>
  {% if badge != blank %}
    <p
      style="
        margin: 0 0 8px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: {{ block.settings.accent_color }};
      "
    >
      {{ badge | escape }}
    </p>
  {% endif %}

  {% if heading != blank %}
    <h3
      style="
        margin: 0 0 6px;
        font-size: 18px;
        font-weight: 600;
        line-height: 1.3;
        color: #1E293B;
      "
    >
      {{ heading | escape }}
    </h3>
  {% endif %}

  {% if body != blank %}
    <div
      style="
        font-size: 14px;
        line-height: 1.6;
        color: #64748B;
      "
    >
      {{ body | escape }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Image Squish media note",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "Image Squish"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Optimized product media"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "This product's images were optimized with Image Squish for faster loading and better quality."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#EEF2FF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#C7D2FE"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#4F46E5"
    }
  ]
}
{% endschema %}
